# ── Backend (Render) ─────────────────────────────────────
# Required — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults to gemini-3-flash-preview if unset
GEMINI_MODEL=gemini-3-flash-preview

# Optional — comma-separated list of allowed frontend origins, e.g.
# https://echoed.vercel.app,http://localhost:5173
# Defaults to "*" (any origin) if unset.
ALLOWED_ORIGIN=

# ── Frontend (Vercel) ────────────────────────────────────
# URL of your deployed Render backend's /api/generate route.
# Leave unset for local dev — Vite's dev middleware handles it instead.
VITE_API_URL=
